{
  "name": "azure-ganttops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:local": "node dist/src/app/bootstrap/local-server.js",
    "dev:local": "npm run build && npm run start:local",
    "test": "vitest run",
    "test:e2e": "node ./src/shared/testing/run-e2e.mjs",
    "test:e2e:density": "node ./src/shared/testing/run-e2e.mjs --testNamePattern=\"density|timeline\"",
    "lint": "tsc --noEmit",
    "check:cycles": "tsc --noEmit",
    "quality:ui": "npm run lint && npm run typecheck && npm test && npm run test:e2e",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  }
}
