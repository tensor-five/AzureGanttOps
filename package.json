{
  "name": "azure-ganttops",
  "version": "1.8.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:ui-shell",
    "start:local": "node dist/src/app/bootstrap/local-server.js",
    "app:start": "node scripts/one-click-start.mjs",
    "prepare": "husky",
    "build:ui-shell": "esbuild src/app/bootstrap/local-ui-entry.ts --bundle --format=esm --platform=browser --outfile=dist/src/app/bootstrap/local-ui-entry.browser.js",
    "dev:local": "npm run build && npm run start:local",
    "test": "vitest run",
    "test:e2e": "node ./src/shared/testing/run-e2e.mjs",
    "test:e2e:density": "node ./src/shared/testing/run-e2e.mjs --grep \"density|timeline\"",
    "lint": "tsc --noEmit",
    "check:cycles": "node ./scripts/check-cycles.mjs",
    "secrets:scan": "node ./scripts/secret-scan.mjs",
    "secrets:scan:staged": "node ./scripts/secret-scan.mjs --staged",
    "quality:ui": "npm run lint && npm run typecheck && npm run check:cycles && npm test && npm run test:e2e",
    "quality:gate:phase6": "npm run lint && npm run typecheck && npm run check:cycles && npm test && npm run test:e2e",
    "quality:gate": "npm run typecheck && npm run check:cycles && npm test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*": "node ./scripts/secret-scan.mjs --files"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "isomorphic-dompurify": "^3.18.0",
    "lowdb": "^7.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.18.0",
    "remark-gfm": "^4.0.1"
  }
}
